Lympho_per_region <- read_excel("A:/Ramified vs foamy/Lymph_vasvsnonvas/lymType_byRegion.xlsx", 
                          sheet = "per donor")

Lympho_glm <- glm(cells_per_mm2 ~ region_vas, family = 'quasipoisson', data=Lympho_per_region)
anova(Lympho_glm)
emm <- emmeans(Lympho_glm, "region_vas")
pairwise_contrasts <- contrast(emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

Lympho_vas <- subset (Lympho_per_region, vasType == "vascular")

Lympho_vas_glm <- glm(cells_per_mm2 ~ region, family = 'quasipoisson', data=Lympho_vas)
anova(Lympho_vas_glm)
emm <- emmeans(Lympho_vas_glm, "region")
pairwise_contrasts <- contrast(emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

Lympho_par <- subset (Lympho_per_region, vasType == "non-vascular")

Lympho_par_glm <- glm(cells_per_mm2 ~ region, family = 'quasipoisson', data=Lympho_par)
anova(Lympho_par_glm)
emm <- emmeans(Lympho_par_glm, "region")
pairwise_contrasts <- contrast(emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

