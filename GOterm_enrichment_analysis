#GO term enrichment analysis

data_GSEA_border_up <- read_excel("A:/Ramified vs foamy/DE genes pseudobulk/NEW-analysis/David/BorderFvsR_up_GSEA.xlsx", 
                   sheet = "Selected")


data_GSEA_border_up_filtered <- subset(data_GSEA_border_up, Category == "GOTERM_BP_DIRECT" | Category == "GOTERM_MF_DIRECT" | Category == "GOTERM_CC_DIRECT" | Category == "KEGG_PATHWAY" | Category == "UP_KW_BIOLOGICAL_PROCESS" | Category == "UP_KW_DISEASE")
data_GSEA_border_up_filtered <- data_GSEA_border_up_filtered %>%
  mutate(Term = reorder(Term, Fold_Enrichment))
data_GSEA_border_up_filtered$Term <- as.factor(data_GSEA_border_up_filtered$Term)

ggplot(data_GSEA_border_up_filtered, aes(x = Fold_Enrichment, y = Term, color = FDR, size = Count)) +
  geom_point() +
  scale_color_gradient(low = "red", high = "blue") + # Adjust color scale as needed
  labs(title = "Border F vs R up",
       x = "Fold Enrichment",
       y = "Term",
       color = "FDR") +
  theme_minimal()



