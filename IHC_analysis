#DE GENES VALIDATION

#Ferritin
FTH <- read_excel("//vs03/VS03-IMM-2/Spatialseq_project/BGI_RamifiedvsFoamy/Data_Analysis/IHC/DEs/Results.xlsx",
                  sheet = "Ferritin")


FTH_glm <- glm(FTHpos_per_mm ~ Region, family = 'quasipoisson', data=FTH)
emm <- emmeans(FTH_glm, "Region")
pairwise_contrasts <- contrast (emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

FTH_noHLA_glm <- glm(HLAnegFTHpos_per_mm ~ Region, family = 'quasipoisson', data=FTH)
emm <- emmeans(FTH_noHLA_glm, "Region")
pairwise_contrasts <- contrast (emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

FTH_HLA_glm <- glm(HLAposFTHpos_per_mm ~ Region, family = 'quasipoisson', data=FTH)
emm <- emmeans(FTH_HLA_glm, "Region")
pairwise_contrasts <- contrast (emm, method = "pairwise", adjust = "fdr")
summary(pairwise_contrasts)

