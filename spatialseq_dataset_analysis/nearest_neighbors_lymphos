df <- read.csv("T:/Lab Absinta/15_ALETTA/Spatial_Seq_paper/CellReports_RB2/neighbourhood/all_lymphocytes_to_others_distances.csv")
df <- read.csv("C:/Users/avandenbosch/Documents/Spatial/all_lymphocytes_to_others_distances.csv")

df_long <- df %>%
  pivot_longer(
    cols = starts_with("Distance"),
    names_to = "CellType",
    values_to = "Distance"
  ) %>%
  mutate(
    CellType = gsub("Distance_to_", "", CellType)  # cleaner labels
  )


# Calculate averages per donor
avg_table_donor <- df_long %>%
  group_by(Donor, CellType, Location) %>%
  summarise(
    Mean_Distance = mean(Distance, na.rm = TRUE),
    SD_Distance = sd(Distance, na.rm = TRUE),
    N = n(),
    .groups = "drop"
  )

avg_table <- avg_table_donor %>%
  group_by(CellType, Location) %>%
  summarise(
    mean = mean(Mean_Distance, na.rm = TRUE),
    sd   = sd(Mean_Distance, na.rm = TRUE),
    n    = sum(!is.na(Mean_Distance)),
    sem  = sd / sqrt(n)
  )

# Boxplot
dodge <- position_dodge(width = 0.9)

ggplot()+
  geom_bar(
    data = avg_table,
    aes(x = CellType, y=mean, fill=Location),
    stat = "identity", position = position_dodge(width = 0.9),
    color="black", width = 0.7)+
  geom_jitter(
    data = df_long,
    aes(x=CellType, y=Distance, color= Location),
    position = dodge,
    size = 1.8, alpha = 0.25)+
  geom_errorbar(
    data = avg_table,
    aes(x=CellType, ymin=mean, ymax=mean + sd, group = Location),
    position = position_dodge(width = 0.9),
    width = 0.2)+
  scale_fill_brewer(palette = "Set2")+
  scale_color_brewer(palette = "Set2")+
  labs(
    x="Cell Type",
    y = "Distance",
    title = "Nearest neighbour distance")+
  theme_minimal(base_size = 13) +
  theme(
    panel.grid.major = element_line(color = "grey85"),
    panel.grid.minor = element_blank(),
    legend.position = "top",
    axis.text.x = element_text(angle=0, hjust = 1)
  )



celltype_list <- split (avg_table_donor, avg_table_donor$CellType)
run_tests <- function (data) {
  pairwise.t.test(
    x=data$Mean_Distance,
    g=data$Location,
    p.adjust.method = "BH"
  )
}

test_results <- lapply(celltype_list, run_tests)
test_results

