#make plots
cellstates_all <- read_excel("A:/Ramified vs foamy/Cell_types_seq/Celltypes_state.xlsx",
                             sheet="all")
id_vars <- c("DonorID", "Region")
cellstates_all_long <- pivot_longer(cellstates_all,
                                    cols= -c(DonorID, Region, Diagnosis),
                                    names_to = "Variable",
                                    values_to = "Density")

cellstates_all_long <- cellstates_all_long %>%
  mutate(Type = case_when(
    grepl("astro", Variable) ~ "astro",
    grepl("opc", Variable) ~"opc",    
    grepl("imm", Variable) ~"imm",
    grepl("oligo", Variable) ~"oligo",
    TRUE ~ "other"
  ))

cellstates_long_oligo <- subset (cellstates_all_long, Type == "oligo")
ggplot(cellstates_long_oligo, aes(x=Region, y=Density, fill=Variable))+
  geom_violin(scale="width")+
  scale_x_discrete(limits=c("WM","NAWM","Centre ramified", "Centre foamy", "Border ramified", "Border foamy", "Peri-lesion ramified", "Peri-lesion foamy"))+
