summary_data <- merged_Cellchat_borderF %>%
  group_by(source_name, target_name) %>%
  dplyr::summarize(frequency = n()) %>%
  ungroup()

cell_types <- unique(c(summary_data$source_name, summary_data$target_name))
color_palette <- colorRampPalette(RColorBrewer::brewer.pal(8, "Paired"))(length(cell_types))
names(color_palette) <- cell_types

# Create the chord diagram
chordDiagram(
  summary_data,
  directional = FALSE,  # Disable directional arrows
  transparency = 0.5,
  annotationTrack = "grid",
  preAllocateTracks = list(track.height = 0.1),
  grid.col = color_palette
)

# Loop through summary_data to customize line widths
for (i in 1:nrow(summary_data)) {
  circos.link(
    sector.index1 = summary_data$source_name[i],
    sector.index2 = summary_data$target_name[i],
    col = color_palette[summary_data$source_name[i]],  # Use color based on source
    lwd = summary_data$frequency[i] * 0.5  # Scale the width if necessary
  )
}






