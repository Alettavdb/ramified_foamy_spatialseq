df_freq_merged <- merge(df_freq, target_type_sum, by = "Target_name", suffixes = c("", "_sum"))
df_freq_normalized <- df_freq_merged
df_freq_normalized$frequency <- df_freq_merged$frequency / df_freq_merged$frequency_sum

ggplot(df_freq_normalized, aes(x = Target_name, y = Source_name, fill = frequency)) +
  geom_tile() +
  geom_text(aes(label = round(as.numeric(freq_table),2)),color="black",size=3)+
  scale_fill_gradient(low = "azure1", high = "blue") +
  labs(x = "Target Type", y = "Source Type", fill = "Normalized Frequency", title = invest) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))


