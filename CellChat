####PLOT INTERACTIONS OF INTEREST

CellChat_all <- read_excel("A:/Ramified vs foamy/Cellchat/Results.xlsx",
                                        sheet = "All")

interaction_freq <- CellChat_all %>%
  group_by(interaction_name) %>%
  summarise(frequency = n()) %>%
  arrange(desc(frequency))  # Arrange in descending order of frequency

invest <- 'CLDN11_CLDN11'
interest <- subset(CellChat_all, interaction_name == invest)

for( i in 1:length(interaction_freq$interaction_name)){
  
  invest <- unique(interaction_freq$interaction_name)[i]
  interest <- subset(CellChat_all, interaction_name == invest)
  
  
  freq_table <- table(interest$source_name, interest$target_name)
  df_freq <- as.data.frame(as.table(freq_table))
  colnames(df_freq) <- c("Source_name", "Target_name", "frequency")
  target_type_sum <- aggregate(frequency ~ Target_name, data = df_freq, sum)
  df_freq_merged <- merge(df_freq, target_type_sum, by = "Target_name", suffixes = c("", "_sum"))
  df_freq_normalized <- df_freq_merged
  df_freq_normalized$frequency <- df_freq_merged$frequency / df_freq_merged$frequency_sum
  
  plot <- ggplot(df_freq_normalized, aes(x = Target_name, y = Source_name, fill = frequency)) +
    geom_tile() +
    geom_text(aes(label = round(as.numeric(freq_table),2)),color="black",size=3)+
    scale_fill_gradient(low = "azure1", high = "blue") +
    labs(x = "Target Type", y = "Source Type", fill = "Normalized Frequency", title = invest) +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))
  
  ggsave(paste0("A:/Ramified vs foamy/Cellchat/ligands_per_type/norm/",i,"_", invest, ".png"), plot = plot, device = "png")
  
}



